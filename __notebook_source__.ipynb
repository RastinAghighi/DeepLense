import sys, os, random, glob, time
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
import torch.nn.functional as F
from torch.utils.data import Dataset, DataLoader
from pathlib import Path
from skimage.metrics import structural_similarity as ssim_metric
from skimage.metrics import peak_signal_noise_ratio as psnr_metric

# Setup
sys.path.insert(0, "/kaggle/input/datasets/rastinaghighi/deeplense-src")
from src.edsr import EDSR
from src.losses import CompositeSRLoss
from src.metrics import compute_metrics, bootstrap_ci, self_ensemble_predict

SEED = 42
random.seed(SEED)
np.random.seed(SEED)
torch.manual_seed(SEED)
torch.cuda.manual_seed_all(SEED)
device = torch.device("cuda")
print("Device:", device, torch.cuda.get_device_name(0))

# ── Data Loading ──
HR_DIR = "/kaggle/input/datasets/rastinaghighi/deeplense-via-simulated/Dataset/HR"
LR_DIR = "/kaggle/input/datasets/rastinaghighi/deeplense-via-simulated/Dataset/LR"

hr_files = {Path(f).stem: f for f in glob.glob(os.path.join(HR_DIR, "*.npy"))}
lr_files = {Path(f).stem: f for f in glob.glob(os.path.join(LR_DIR, "*.npy"))}
matched_keys = sorted(set(hr_files.keys()) & set(lr_files.keys()))
print("Matched pairs:", len(matched_keys))

keys = matched_keys.copy()
rng = random.Random(SEED)
rng.shuffle(keys)
split = int(0.9 * len(keys))
train_keys, test_keys = keys[:split], keys[split:]
print("Train:", len(train_keys), "Test:", len(test_keys))

# ── Dataset ──
class SRDataset(Dataset):
    def __init__(self, keys, hr_files, lr_files, augment=False):
        self.keys = keys
        self.hr = hr_files
        self.lr = lr_files
        self.augment = augment
    def __len__(self):
        return len(self.keys)
    def __getitem__(self, idx):
        k = self.keys[idx]
        hr = np.load(self.hr[k]).astype(np.float32)
        lr = np.load(self.lr[k]).astype(np.float32)
        if self.augment:
            rot = random.randint(0, 3)
            if rot > 0:
                hr = np.rot90(hr, rot, axes=(1,2)).copy()
                lr = np.rot90(lr, rot, axes=(1,2)).copy()
            if random.random() > 0.5:
                hr = np.flip(hr, axis=2).copy()
                lr = np.flip(lr, axis=2).copy()
            if random.random() > 0.5:
                hr = np.flip(hr, axis=1).copy()
                lr = np.flip(lr, axis=1).copy()
        return torch.from_numpy(hr), torch.from_numpy(lr)

train_loader = DataLoader(SRDataset(train_keys, hr_files, lr_files, augment=True),
                          batch_size=16, shuffle=True, num_workers=2, pin_memory=True)
test_loader = DataLoader(SRDataset(test_keys, hr_files, lr_files, augment=False),
                         batch_size=1, shuffle=False, num_workers=2)

# ── Model ──
model = EDSR(n_channels=1, n_feats=64, n_resblocks=16, scale=2).to(device)
print("Parameters:", sum(p.numel() for p in model.parameters()))

# ── Training (Composite Loss) ──
criterion = CompositeSRLoss(lambda_flux=0.05, lambda_bp=0.1)
optimizer = optim.Adam(model.parameters(), lr=1e-4)
scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode="min", factor=0.5, patience=5)

NUM_EPOCHS = 100
PATIENCE = 10
best_val_loss = float("inf")
patience_counter = 0
best_state = None
history = {"train_loss":[], "val_loss":[], "val_psnr":[], "val_ssim":[]}

print("\n" + "="*70)
print("TRAINING EDSR — COMPOSITE LOSS (L1 + Flux + BackProjection)")
print("="*70)
t0 = time.time()

for epoch in range(NUM_EPOCHS):
    # Train
    model.train()
    tloss, n = 0.0, 0
    for hr, lr in train_loader:
        hr, lr = hr.to(device), lr.to(device)
        optimizer.zero_grad()
        sr = model(lr)
        loss, parts = criterion(sr, hr, lr)
        loss.backward()
        optimizer.step()
        tloss += loss.item() * lr.size(0)
        n += lr.size(0)
    tloss /= n

    # Validate
    model.eval()
    vloss, vpsnr, vssim = 0.0, [], []
    with torch.no_grad():
        for hr, lr in test_loader:
            hr, lr = hr.to(device), lr.to(device)
            sr = model(lr)
            loss, _ = criterion(sr, hr, lr)
            vloss += loss.item()
            s = np.clip(sr[0,0].cpu().numpy(), 0, 1)
            h = np.clip(hr[0,0].cpu().numpy(), 0, 1)
            vpsnr.append(psnr_metric(h, s, data_range=1.0))
            vssim.append(ssim_metric(h, s, data_range=1.0))
    vloss /= len(test_keys)
    vpsnr_m, vssim_m = np.mean(vpsnr), np.mean(vssim)

    history["train_loss"].append(tloss)
    history["val_loss"].append(vloss)
    history["val_psnr"].append(vpsnr_m)
    history["val_ssim"].append(vssim_m)

    scheduler.step(vloss)
    lr_now = optimizer.param_groups[0]["lr"]

    mark = ""
    if vloss < best_val_loss:
        best_val_loss = vloss
        best_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}
        patience_counter = 0
        mark = " *"
    else:
        patience_counter += 1

    if (epoch+1) % 5 == 0 or epoch == 0 or mark:
        elapsed = (time.time() - t0) / 60
        print("Ep %3d/%d | TrLoss: %.5f | ValLoss: %.5f | PSNR: %.2f | SSIM: %.4f | LR: %.1e | %.1fmin%s"
              % (epoch+1, NUM_EPOCHS, tloss, vloss, vpsnr_m, vssim_m, lr_now, elapsed, mark))

    if patience_counter >= PATIENCE:
        print("\nEarly stopping at epoch", epoch+1)
        break

# Restore best and save
model.load_state_dict(best_state)
model = model.to(device)
torch.save(best_state, "/kaggle/working/edsr_simulated_best.pth")
print("\nSaved: /kaggle/working/edsr_simulated_best.pth")
print("Total training time: %.1f minutes" % ((time.time()-t0)/60))

# ── Evaluation ──
print("\n" + "="*70)
print("EVALUATION")
print("="*70)
model.eval()
bic_m = {"mse":[], "ssim":[], "psnr":[], "flux_error":[]}
edsr_m = {"mse":[], "ssim":[], "psnr":[], "flux_error":[]}
ens_m = {"mse":[], "ssim":[], "psnr":[], "flux_error":[]}

for hr, lr in test_loader:
    hr_np = hr[0,0].numpy()
    lr_np = lr[0,0].numpy()

    # Bicubic
    bic = F.interpolate(lr, size=hr.shape[-2:], mode="bicubic", align_corners=False)
    for k,v in compute_metrics(bic[0,0].numpy(), hr_np).items():
        bic_m[k].append(v)

    # EDSR
    with torch.no_grad():
        sr = model(lr.to(device)).cpu()
    for k,v in compute_metrics(sr[0,0].numpy(), hr_np).items():
        edsr_m[k].append(v)

    # EDSR+ ensemble
    sr_ens = self_ensemble_predict(model, lr, device)
    for k,v in compute_metrics(sr_ens[0,0].numpy(), hr_np).items():
        ens_m[k].append(v)

print("\n%-14s %-24s %-24s %-24s" % ("Metric", "Bicubic", "EDSR", "EDSR+"))
print("-"*86)
for metric in ["psnr", "ssim", "mse", "flux_error"]:
    b, e, ep = np.mean(bic_m[metric]), np.mean(edsr_m[metric]), np.mean(ens_m[metric])
    bs, es, eps = np.std(bic_m[metric]), np.std(edsr_m[metric]), np.std(ens_m[metric])
    print("%-14s %.4f +/- %.4f    %.4f +/- %.4f    %.4f +/- %.4f" % (metric.upper(), b, bs, e, es, ep, eps))

print("\nDone! Download edsr_simulated_best.pth from /kaggle/working/")


import os
for f in os.listdir("/kaggle/working"):
    size = os.path.getsize(os.path.join("/kaggle/working", f))
    print(f, "%.1f MB" % (size/1e6))


